# Local Brain v2 — variables de entorno
# Copia este archivo a .env y ajusta los valores

# Ruta al vault de Obsidian
OBSIDIAN_VAULT=~/Projects/yggdrasil-dew

# Ollama
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text

# Alternativas LLM local (descomenta para cambiar):
# LLM_MODEL=llama3.2:3b       # más ligero, peor español
# LLM_MODEL=qwen2.5:7b        # más potente, ~5.5GB VRAM
# LLM_MODEL=gemma3:4b         # buena alternativa

# Alternativas embed (descomenta si nomic falla en español):
# EMBED_MODEL=bge-m3          # mejor multilingüe, +570MB VRAM
# EMBED_MODEL=nomic-embed-text:v1.5  # upgrade seguro sin cambiar código
