# =============================================================================
# .env.template — Variables de entorno Batcueva
# Copiar a .env y rellenar valores reales
# NUNCA subir .env al repo
# =============================================================================

# --- Puertos servicios ---
OLLAMA_PORT=11434
OLLAMA_EMBEDDINGS_PORT=11435
OPEN_WEBUI_PORT=3001
QDRANT_PORT=6333
N8N_PORT=5678
GITEA_PORT=3003
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
PORTAINER_PORT=9000
UPTIME_KUMA_PORT=3002
CODE_SERVER_PORT=8443

# --- Seguridad ---
N8N_ENCRYPTION_KEY=
LITELLM_MASTER_KEY=

# --- Telegram (THDORA) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Backup Restic 3-2-1 ---
RESTC_REPO_LOCAL=/mnt/backup/restic
RESTC_REPO_SFTP=sftp:varopc@192.168.1.100:/backup/restic-madre
RESTC_REPO_B2=b2:batcueva-backup:/restic
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# --- Backblaze B2 ---
# Crear en: https://www.backblaze.com/b2/buckets.html
# Bucket: batcueva-backup (privado)
# App Key: permisos solo lectura/escritura en ese bucket
